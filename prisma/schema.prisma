generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  orders    Order[]
  reviews   Review[]
  createdAt DateTime @default(now())
}

model Laptop {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  price         Float
  discountPrice Float?
  brand         String
  processor     String
  ram           String
  storage       String
  gpu           String
  screenSize    String
  battery       String
  stock         Int
  featured      Boolean  @default(false)
  category      String
  images        String[]
  reviews       Review[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      Json
  total         Float
  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  laptopId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  laptop    Laptop   @relation(fields: [laptopId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}
